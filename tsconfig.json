{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"types": [
			"mocha"
		],
		"moduleResolution": "Node16", /* Essential for finding modern dependencies */
		"outDir": "dist", /* Matches your package.json 'main' */
		"rootDir": "src",
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true, /* Helps with importing CommonJS libs like 'css' or 'ws' */
		"skipLibCheck": true, /* Speeds up build and ignores conflicts in @types */
		"resolveJsonModule": true /* Allows you to import your package.json if needed */
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}